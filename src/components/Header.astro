---
const currentPath = Astro.url.pathname;

const mainLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/servicios', label: 'Servicios' },
  { href: '/metodologia', label: 'Metodología' },
  { href: '/casos', label: 'Casos de Estudio' },
];

const careerLink = { href: '/career', label: 'Perfil Profesional' };

const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
};
---
<header class="fixed top-0 w-full z-40 bg-surface/80 backdrop-blur-md border-b border-outline-variant/10 transition-all duration-300" id="main-header">
    <nav class="flex justify-between items-center px-gutter h-20 max-w-container-max mx-auto relative">
        <div class="flex items-center gap-2 z-50">
            <a href="/" aria-label="Volver al inicio" class="font-headline-md text-headline-md font-bold text-on-surface hover:text-primary transition-colors">RenkaiDev</a>
        </div>
        
        <!-- Desktop Menu -->
        <div class="hidden md:flex items-center gap-8">
            {mainLinks.map((link) => (
                <a 
                    href={link.href} 
                    class={`font-body-md text-body-md transition-colors duration-200 ${
                        isActive(link.href) 
                            ? 'text-primary font-bold border-b-2 border-primary pb-1' 
                            : 'text-on-surface-variant font-medium hover:text-primary'
                    }`}
                >
                    {link.label}
                </a>
            ))}
            <div class="h-6 w-px bg-outline-variant/30"></div>
            <a 
                href={careerLink.href} 
                class={`font-body-md text-body-md transition-all duration-200 flex items-center gap-2 ${
                    isActive(careerLink.href) 
                        ? 'text-primary font-bold border-b-2 border-primary pb-1' 
                        : 'text-primary/80 font-medium hover:text-primary'
                }`}
            >
                <span class="material-symbols-outlined notranslate text-[18px]" translate="no">badge</span>
                {careerLink.label}
            </a>
        </div>
        <div class="hidden md:flex items-center gap-4">
            <div class="gtranslate_wrapper"></div>
        </div>

        <!-- Mobile Menu Button -->
        <button id="mobile-menu-btn" class="md:hidden flex flex-col justify-center items-center w-10 h-10 z-[60] relative focus:outline-none" aria-label="Abrir menú">
            <span class="w-6 h-0.5 bg-on-surface transition-all duration-300 rounded-full block absolute origin-center transform -translate-y-2"></span>
            <span class="w-6 h-0.5 bg-on-surface transition-all duration-300 rounded-full block absolute origin-center transform"></span>
            <span class="w-6 h-0.5 bg-on-surface transition-all duration-300 rounded-full block absolute origin-center transform translate-y-2"></span>
        </button>
    </nav>
</header>

<!-- Overlay for Sidebar -->
<div id="mobile-overlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 z-50 md:hidden"></div>

<!-- Mobile Sidebar -->
<div id="mobile-sidebar" class="fixed inset-y-0 right-0 w-[80%] max-w-sm bg-surface-container-high/95 backdrop-blur-xl border-l border-outline-variant/10 shadow-2xl transform translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] z-[55] flex flex-col md:hidden">
    <div class="flex flex-col pt-24 px-8 gap-6 h-full overflow-y-auto pb-8">
        {mainLinks.map((link) => (
            <a 
                href={link.href} 
                class={`font-body-md text-xl transition-colors duration-200 ${
                    isActive(link.href) 
                        ? 'text-primary font-bold' 
                        : 'text-on-surface-variant hover:text-primary'
                }`}
            >
                {link.label}
            </a>
        ))}
        <div class="h-px w-full bg-outline-variant/30 my-2"></div>
        <a 
            href={careerLink.href} 
            class={`font-body-md text-xl transition-colors duration-200 flex items-center gap-2 ${
                isActive(careerLink.href) 
                    ? 'text-primary font-bold' 
                    : 'text-primary/80 hover:text-primary'
            }`}
        >
            <span class="material-symbols-outlined notranslate" translate="no">badge</span>
            {careerLink.label}
        </a>
        <div class="mt-4 flex flex-col items-center gap-4">
            <div class="gtranslate_wrapper"></div>
        </div>
    </div>
</div>

<script>
    // Header Scroll behavior
    window.addEventListener('scroll', () => {
        const header = document.getElementById('main-header');
        if (header) {
            if (window.scrollY > 20) {
                header.classList.add('h-16');
                header.querySelector('nav')?.classList.remove('h-20');
                header.querySelector('nav')?.classList.add('h-16');
            } else {
                header.classList.remove('h-16');
                header.querySelector('nav')?.classList.add('h-20');
                header.querySelector('nav')?.classList.remove('h-16');
            }
        }
    });

    // Mobile Menu Toggle
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileSidebar = document.getElementById('mobile-sidebar');
    const mobileOverlay = document.getElementById('mobile-overlay');
    const lines = mobileBtn?.querySelectorAll('span');
    let isMenuOpen = false;

    const toggleMenu = () => {
        isMenuOpen = !isMenuOpen;
        
        if (isMenuOpen) {
            mobileSidebar?.classList.remove('translate-x-full');
            mobileOverlay?.classList.remove('opacity-0', 'pointer-events-none');
            // Animate hamburger to X
            if(lines && lines.length === 3) {
                lines[0].classList.add('translate-y-0', 'rotate-45');
                lines[0].classList.remove('-translate-y-2');
                lines[1].classList.add('opacity-0');
                lines[2].classList.add('translate-y-0', '-rotate-45');
                lines[2].classList.remove('translate-y-2');
            }
            document.body.style.overflow = 'hidden'; // Prevent scrolling
        } else {
            mobileSidebar?.classList.add('translate-x-full');
            mobileOverlay?.classList.add('opacity-0', 'pointer-events-none');
            // Animate X to hamburger
            if(lines && lines.length === 3) {
                lines[0].classList.remove('translate-y-0', 'rotate-45');
                lines[0].classList.add('-translate-y-2');
                lines[1].classList.remove('opacity-0');
                lines[2].classList.remove('translate-y-0', '-rotate-45');
                lines[2].classList.add('translate-y-2');
            }
            document.body.style.overflow = '';
        }
    };

    mobileBtn?.addEventListener('click', toggleMenu);
    mobileOverlay?.addEventListener('click', toggleMenu);

    // Close menu when clicking a link
    const mobileLinks = mobileSidebar?.querySelectorAll('a');
    mobileLinks?.forEach(link => {
        link.addEventListener('click', () => {
            if (isMenuOpen) toggleMenu();
        });
    });
</script>
