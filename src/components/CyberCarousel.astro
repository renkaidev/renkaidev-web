---
---
<div class="relative w-full max-w-4xl mx-auto h-[350px] md:h-[300px]" id="cyber-carousel">
    <!-- Navigation -->
    <div class="absolute top-1/2 -translate-y-1/2 w-full flex justify-between z-20 pointer-events-none px-4 -mx-4 md:mx-0">
        <button aria-label="Slide anterior" id="prev-slide" class="w-10 h-10 md:w-12 md:h-12 rounded-full border border-primary/30 bg-surface/50 backdrop-blur-sm text-primary flex items-center justify-center pointer-events-auto hover:bg-primary/10 hover:border-primary hover:shadow-[0_0_15px_rgba(137,206,255,0.4)] transition-all">
            <span class="material-symbols-outlined">chevron_left</span>
        </button>
        <button aria-label="Siguiente slide" id="next-slide" class="w-10 h-10 md:w-12 md:h-12 rounded-full border border-primary/30 bg-surface/50 backdrop-blur-sm text-primary flex items-center justify-center pointer-events-auto hover:bg-primary/10 hover:border-primary hover:shadow-[0_0_15px_rgba(137,206,255,0.4)] transition-all">
            <span class="material-symbols-outlined">chevron_right</span>
        </button>
    </div>

    <!-- Slides Container -->
    <div class="relative w-full h-full px-12 md:px-16">
        <!-- Slide 1 -->
        <div class="carousel-slide absolute inset-0 flex flex-col items-center justify-center text-center p-6 md:p-8 glass-card rounded-2xl border border-primary/20 bg-surface-container-low/40 opacity-100 z-10" data-index="0">
            <div class="w-12 h-12 md:w-16 md:h-16 rounded-full border-2 border-primary text-primary shadow-[0_0_15px_rgba(137,206,255,0.5)] flex items-center justify-center font-display-lg text-xl md:text-2xl font-bold mb-4 md:mb-6">01</div>
            <h4 class="font-headline-md text-xl md:text-[28px] text-on-surface mb-2 md:mb-4">Descubrimiento</h4>
            <p class="text-on-surface-variant text-body-md md:text-body-lg max-w-lg">Análisis exhaustivo de tus necesidades actuales y la arquitectura subyacente de tu negocio para trazar el mapa correcto.</p>
        </div>
        <!-- Slide 2 -->
        <div class="carousel-slide absolute inset-0 flex flex-col items-center justify-center text-center p-6 md:p-8 glass-card rounded-2xl border border-primary/20 bg-surface-container-low/40 opacity-0 scale-95 pointer-events-none" data-index="1">
            <div class="w-12 h-12 md:w-16 md:h-16 rounded-full border-2 border-primary text-primary shadow-[0_0_15px_rgba(137,206,255,0.5)] flex items-center justify-center font-display-lg text-xl md:text-2xl font-bold mb-4 md:mb-6">02</div>
            <h4 class="font-headline-md text-xl md:text-[28px] text-on-surface mb-2 md:mb-4">Planificación</h4>
            <p class="text-on-surface-variant text-body-md md:text-body-lg max-w-lg">Diseño de la hoja de ruta técnica con hitos claros, stack tecnológico justificado y presupuestos sin costos ocultos.</p>
        </div>
        <!-- Slide 3 -->
        <div class="carousel-slide absolute inset-0 flex flex-col items-center justify-center text-center p-6 md:p-8 glass-card rounded-2xl border border-primary/20 bg-surface-container-low/40 opacity-0 scale-95 pointer-events-none" data-index="2">
            <div class="w-12 h-12 md:w-16 md:h-16 rounded-full border-2 border-primary text-primary shadow-[0_0_15px_rgba(137,206,255,0.5)] flex items-center justify-center font-display-lg text-xl md:text-2xl font-bold mb-4 md:mb-6">03</div>
            <h4 class="font-headline-md text-xl md:text-[28px] text-on-surface mb-2 md:mb-4">Ejecución</h4>
            <p class="text-on-surface-variant text-body-md md:text-body-lg max-w-lg">Implementación ágil bajo estándares industriales de calidad, priorizando código limpio, rendimiento y seguridad estructural.</p>
        </div>
        <!-- Slide 4 -->
        <div class="carousel-slide absolute inset-0 flex flex-col items-center justify-center text-center p-6 md:p-8 glass-card rounded-2xl border border-primary/20 bg-surface-container-low/40 opacity-0 scale-95 pointer-events-none" data-index="3">
            <div class="w-12 h-12 md:w-16 md:h-16 rounded-full border-2 border-primary text-primary shadow-[0_0_15px_rgba(137,206,255,0.5)] flex items-center justify-center font-display-lg text-xl md:text-2xl font-bold mb-4 md:mb-6">04</div>
            <h4 class="font-headline-md text-xl md:text-[28px] text-on-surface mb-2 md:mb-4">Entrega Continua</h4>
            <p class="text-on-surface-variant text-body-md md:text-body-lg max-w-lg">Despliegue final con integración DevOps, capacitación técnica al equipo interno y monitoreo post-lanzamiento.</p>
        </div>
    </div>
    
    <!-- Progress Indicators -->
    <div class="absolute -bottom-10 left-1/2 -translate-x-1/2 flex gap-3">
        <div class="slide-indicator w-8 h-1 rounded-full bg-primary shadow-[0_0_10px_rgba(137,206,255,0.8)] transition-all duration-300"></div>
        <div class="slide-indicator w-2 h-1 rounded-full bg-outline-variant transition-all duration-300"></div>
        <div class="slide-indicator w-2 h-1 rounded-full bg-outline-variant transition-all duration-300"></div>
        <div class="slide-indicator w-2 h-1 rounded-full bg-outline-variant transition-all duration-300"></div>
    </div>
</div>

<script>
    import { gsap } from 'gsap';
    
    const initCarousel = () => {
        const slides = document.querySelectorAll('.carousel-slide');
        const indicators = document.querySelectorAll('.slide-indicator');
        const btnNext = document.getElementById('next-slide');
        const btnPrev = document.getElementById('prev-slide');
        
        if(!slides.length || !btnNext || !btnPrev) return;

        let currentIndex = 0;
        let isAnimating = false;

        const goToSlide = (index: number) => {
            if(isAnimating || index === currentIndex) return;
            isAnimating = true;

            const currentSlide = slides[currentIndex] as HTMLElement;
            const nextSlide = slides[index] as HTMLElement;

            // Update indicators
            indicators.forEach((ind, i) => {
                if(i === index) {
                    gsap.to(ind, { width: 32, backgroundColor: 'var(--color-primary)', boxShadow: '0 0 10px rgba(137,206,255,0.8)', duration: 0.3 });
                } else {
                    gsap.to(ind, { width: 8, backgroundColor: 'var(--color-outline-variant)', boxShadow: 'none', duration: 0.3 });
                }
            });

            // Animate out current
            gsap.to(currentSlide, {
                opacity: 0,
                scale: 0.95,
                x: index > currentIndex ? -30 : 30,
                duration: 0.5,
                ease: "power2.inOut",
                onComplete: () => {
                    currentSlide.style.zIndex = '0';
                    currentSlide.style.pointerEvents = 'none';
                }
            });

            // Set initial state for next slide
            gsap.set(nextSlide, {
                opacity: 0,
                scale: 1.05,
                x: index > currentIndex ? 30 : -30,
                zIndex: 10,
                pointerEvents: 'auto'
            });

            // Animate in next
            gsap.to(nextSlide, {
                opacity: 1,
                scale: 1,
                x: 0,
                duration: 0.5,
                delay: 0.1,
                ease: "power2.out",
                onComplete: () => {
                    isAnimating = false;
                    currentIndex = index;
                }
            });
        };

        btnNext.addEventListener('click', () => {
            const next = (currentIndex + 1) % slides.length;
            goToSlide(next);
        });

        btnPrev.addEventListener('click', () => {
            const prev = (currentIndex - 1 + slides.length) % slides.length;
            goToSlide(prev);
        });
    };

    // Run on client load
    document.addEventListener('DOMContentLoaded', initCarousel);
</script>
