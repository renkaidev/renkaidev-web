---
---
<!-- Contact Form -->
<div class="glass-card p-8 md:p-12 rounded-[2rem] border border-outline-variant/20 hover:border-primary/30 transition-all duration-300">
    <h3 class="font-headline-md text-headline-md mb-8 text-on-surface">Enviar un mensaje</h3>
    <form id="contact-form" class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label class="block font-code-sm text-[12px] uppercase text-on-surface-variant mb-2" for="nombre">Nombre Completo</label>
                <input id="nombre" name="nombre" required class="w-full bg-surface-container-lowest border border-outline-variant/30 text-on-surface rounded-lg px-4 py-3 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all placeholder:text-outline-variant" placeholder="Ej. Juan Pérez" type="text"/>
            </div>
            <div>
                <label class="block font-code-sm text-[12px] uppercase text-on-surface-variant mb-2" for="email">Email Corporativo</label>
                <input id="email" name="email" required class="w-full bg-surface-container-lowest border border-outline-variant/30 text-on-surface rounded-lg px-4 py-3 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all placeholder:text-outline-variant" placeholder="ejemplo@empresa.com" type="email"/>
            </div>
        </div>
        <div>
            <label class="block font-code-sm text-[12px] uppercase text-on-surface-variant mb-2" for="asunto">Asunto del Proyecto</label>
            <select id="asunto" name="asunto" required class="w-full bg-surface-container-lowest border border-outline-variant/30 text-on-surface rounded-lg px-4 py-3 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all cursor-pointer">
                <option value="Desarrollo Web / Sistema End-to-End">Desarrollo Web / Sistema End-to-End</option>
                <option value="Arquitectura Cloud & DevOps">Arquitectura Cloud & DevOps</option>
                <option value="Auditoría de Seguridad TI">Auditoría de Seguridad TI</option>
                <option value="Transformación Digital para PYME">Transformación Digital para PYME</option>
                <option value="Otro">Otro</option>
            </select>
        </div>
        <div>
            <label class="block font-code-sm text-[12px] uppercase text-on-surface-variant mb-2" for="mensaje">Mensaje</label>
            <textarea id="mensaje" name="mensaje" required minlength="10" class="w-full resize-none bg-surface-container-lowest border border-outline-variant/30 text-on-surface rounded-lg px-4 py-3 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all placeholder:text-outline-variant" placeholder="Cuéntame brevemente tu necesidad..." rows="4"></textarea>
        </div>
        <button class="w-full bg-primary text-on-primary font-bold py-4 rounded-xl hover:shadow-[0_0_20px_rgba(137,206,255,0.4)] hover:scale-[1.02] active:scale-95 transition-all flex items-center justify-center gap-2" type="submit">
            Enviar Mensaje
            <span class="material-symbols-outlined">send</span>
        </button>
    </form>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('contact-form');
        if (form) {
            form.addEventListener('submit', (e) => {
                e.preventDefault();
                
                const nombre = (document.getElementById('nombre') as HTMLInputElement).value;
                const email = (document.getElementById('email') as HTMLInputElement).value;
                const asunto = (document.getElementById('asunto') as HTMLSelectElement).value;
                const mensaje = (document.getElementById('mensaje') as HTMLTextAreaElement).value;
                
                const mailtoSubject = encodeURIComponent(`Nuevo contacto web: ${asunto}`);
                const mailtoBody = encodeURIComponent(`Nombre: ${nombre}\nEmail: ${email}\nAsunto: ${asunto}\n\nMensaje:\n${mensaje}`);
                
                window.location.href = `mailto:pablovaldescontacto@gmail.com?subject=${mailtoSubject}&body=${mailtoBody}`;
            });
        }
    });
</script>
