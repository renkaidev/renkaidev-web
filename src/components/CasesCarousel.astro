---
import { getCollection } from 'astro:content';
const allCases = await getCollection('casos-estudio');
// Ordenamos o seleccionamos algunos (los primeros 4 para el carrusel)
const featuredCases = allCases.slice(0, 4);
---
<div class="relative w-full max-w-5xl mx-auto h-[450px] md:h-[400px]" id="cases-carousel">
    <!-- Navigation -->
    <div class="absolute top-1/2 -translate-y-1/2 w-full flex justify-between z-20 pointer-events-none px-2 -mx-2 md:mx-0">
        <button aria-label="Caso anterior" id="cases-prev-slide" class="w-10 h-10 md:w-12 md:h-12 rounded-full border border-primary/30 bg-surface/80 backdrop-blur-md text-primary flex items-center justify-center pointer-events-auto hover:bg-primary/20 hover:border-primary hover:shadow-[0_0_15px_rgba(137,206,255,0.4)] transition-all">
            <span class="material-symbols-outlined notranslate" translate="no">chevron_left</span>
        </button>
        <button aria-label="Siguiente caso" id="cases-next-slide" class="w-10 h-10 md:w-12 md:h-12 rounded-full border border-primary/30 bg-surface/80 backdrop-blur-md text-primary flex items-center justify-center pointer-events-auto hover:bg-primary/20 hover:border-primary hover:shadow-[0_0_15px_rgba(137,206,255,0.4)] transition-all">
            <span class="material-symbols-outlined notranslate" translate="no">chevron_right</span>
        </button>
    </div>

    <!-- Slides Container -->
    <div class="relative w-full h-full px-8 md:px-16">
        {featuredCases.map((caseStudy, index) => (
            <div class={`cases-slide absolute inset-0 flex flex-col md:flex-row rounded-2xl overflow-hidden border border-outline-variant/30 bg-surface-container-low/60 shadow-[0_0_30px_rgba(0,0,0,0.2)] transition-all duration-500 group ${index === 0 ? 'opacity-100 z-10 pointer-events-auto scale-100' : 'opacity-0 scale-95 pointer-events-none z-0'}`} data-index={index}>
                <div class="md:w-1/2 h-48 md:h-full bg-surface-container overflow-hidden relative">
                    <div class="absolute inset-0 bg-primary/20 mix-blend-overlay z-10 group-hover:bg-transparent transition-colors duration-500"></div>
                    <img alt={caseStudy.data.title} class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105" src={index % 2 === 0 ? "https://images.unsplash.com/photo-1551288049-bebda4e38f71?q=80&w=2070&auto=format&fit=crop" : "https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=2015&auto=format&fit=crop"}/>
                </div>
                <div class="md:w-1/2 p-6 md:p-8 flex flex-col justify-center">
                    <span class="font-code-sm text-primary mb-2 block">{caseStudy.data.status} • {caseStudy.data.year}</span>
                    <h3 class="font-headline-md text-2xl md:text-3xl text-on-surface mb-3 group-hover:text-primary transition-colors">{caseStudy.data.title}</h3>
                    <p class="text-on-surface-variant font-body-md mb-6 line-clamp-3">
                        {caseStudy.data.description}
                    </p>
                    <a href={`/casos/${caseStudy.id}`} class="mt-auto self-start text-primary font-bold flex items-center gap-2 group-hover:gap-3 transition-all hover:text-white">
                        Leer caso completo <span class="material-symbols-outlined notranslate" translate="no">arrow_forward</span>
                    </a>
                </div>
            </div>
        ))}
    </div>
    
    <!-- Progress Indicators -->
    <div class="absolute -bottom-8 left-1/2 -translate-x-1/2 flex gap-3 z-20">
        {featuredCases.map((_, index) => (
            <div class={`cases-indicator h-1.5 rounded-full transition-all duration-300 ${index === 0 ? 'w-8 bg-primary shadow-[0_0_10px_rgba(137,206,255,0.8)]' : 'w-2 bg-outline-variant'}`}></div>
        ))}
    </div>
</div>

<script>
    import { gsap } from 'gsap';
    
    const initCasesCarousel = () => {
        const slides = document.querySelectorAll('.cases-slide');
        const indicators = document.querySelectorAll('.cases-indicator');
        const btnNext = document.getElementById('cases-next-slide');
        const btnPrev = document.getElementById('cases-prev-slide');
        
        if(!slides.length || !btnNext || !btnPrev) return;

        let currentIndex = 0;
        let isAnimating = false;

        const goToSlide = (index: number) => {
            if(isAnimating || index === currentIndex) return;
            isAnimating = true;

            const currentSlide = slides[currentIndex] as HTMLElement;
            const nextSlide = slides[index] as HTMLElement;

            // Update indicators
            indicators.forEach((ind, i) => {
                if(i === index) {
                    gsap.to(ind, { width: 32, backgroundColor: 'var(--color-primary)', boxShadow: '0 0 10px rgba(137,206,255,0.8)', duration: 0.3 });
                } else {
                    gsap.to(ind, { width: 8, backgroundColor: 'var(--color-outline-variant)', boxShadow: 'none', duration: 0.3 });
                }
            });

            // Animate out current
            gsap.to(currentSlide, {
                opacity: 0,
                scale: 0.95,
                x: index > currentIndex ? -50 : 50,
                duration: 0.5,
                ease: "power2.inOut",
                onComplete: () => {
                    currentSlide.style.zIndex = '0';
                    currentSlide.style.pointerEvents = 'none';
                }
            });

            // Set initial state for next slide
            gsap.set(nextSlide, {
                opacity: 0,
                scale: 1.05,
                x: index > currentIndex ? 50 : -50,
                zIndex: 10,
                pointerEvents: 'auto'
            });

            // Animate in next
            gsap.to(nextSlide, {
                opacity: 1,
                scale: 1,
                x: 0,
                duration: 0.5,
                delay: 0.1,
                ease: "power2.out",
                onComplete: () => {
                    isAnimating = false;
                    currentIndex = index;
                }
            });
        };

        btnNext.addEventListener('click', () => {
            const next = (currentIndex + 1) % slides.length;
            goToSlide(next);
        });

        btnPrev.addEventListener('click', () => {
            const prev = (currentIndex - 1 + slides.length) % slides.length;
            goToSlide(prev);
        });
    };

    // Run on client load
    document.addEventListener('DOMContentLoaded', initCasesCarousel);
</script>
