---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CasesCarousel from '../components/CasesCarousel.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout title="Desarrollador Backend Junior & Soluciones TI" description="Desarrollador Backend Junior (Python, FastAPI, PostgreSQL) buscando mi primer empleo formal. También ofrezco desarrollo a medida y automatización para negocios B2B.">
  <Header />
  
  <main class="pt-20">
    <!-- Hero Section -->
    <section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden px-gutter animate-on-scroll">
        <div class="absolute inset-0 z-0"></div>
        <div class="relative z-10 max-w-4xl text-center">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-primary/20 bg-primary/5 text-primary mb-8 animate-pulse shadow-[0_0_15px_rgba(137,206,255,0.2)]">
                <span class="material-symbols-outlined notranslate text-[14px]" translate="no">code</span>
                <span class="font-code-sm text-code-sm uppercase tracking-wider">Desarrollador Backend Junior | Soluciones TI</span>
            </div>
            
            <h1 class="font-display-lg text-display-lg-mobile md:text-[56px] text-on-surface mb-6 leading-tight drop-shadow-[0_0_30px_rgba(137,206,255,0.15)]">
                Desarrollador Backend construyendo <br/> <span class="text-primary hover:text-white transition-colors duration-300 hover:drop-shadow-[0_0_15px_var(--color-primary)]">soluciones reales</span>
            </h1>
            
            <p class="font-body-lg text-[20px] text-on-surface-variant mb-12 max-w-3xl mx-auto leading-relaxed">
                Transformo cuellos de botella en sistemas eficientes. Ya sea automatizando y estructurando procesos para tu negocio B2B, o aportando valor de ingeniería de software en tu equipo técnico.
            </p>
            
            <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
                <!-- Bloom Effect Button -->
                <a href="/#contact" class="w-full sm:w-auto bg-primary text-on-primary px-8 py-4 rounded-xl font-bold flex items-center justify-center gap-2 group transition-all duration-300 hover:shadow-[0_0_30px_rgba(137,206,255,0.6)] hover:bg-white hover:text-primary-container">
                    Solicitar evaluación inicial
                    <span class="material-symbols-outlined notranslate group-hover:translate-x-1 transition-transform" translate="no">arrow_forward</span>
                </a>
                <a href="/casos" class="w-full sm:w-auto border border-outline-variant text-on-surface px-8 py-4 rounded-xl font-bold hover:bg-surface-variant hover:border-primary/50 hover:shadow-[0_0_15px_rgba(137,206,255,0.2)] transition-all flex items-center justify-center gap-2">
                    Ver casos de estudio
                </a>
            </div>
        </div>
    </section>

    <!-- Bifurcación / Dual Journey -->
    <section class="py-12 px-gutter max-w-container-max mx-auto animate-on-scroll">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Path 1: B2B -->
            <a href="/servicios" class="glass-card p-8 rounded-2xl flex flex-col items-center text-center group hover:border-primary/50 transition-all hover:-translate-y-1 hover:shadow-[0_0_30px_rgba(137,206,255,0.15)] relative overflow-hidden">
                <div class="absolute inset-0 bg-primary/5 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                <span class="material-symbols-outlined notranslate text-[48px] text-primary mb-4" translate="no">domain</span>
                <h2 class="font-headline-md text-2xl text-on-surface mb-3 group-hover:text-primary transition-colors">¿Buscas desarrollo a medida para tu negocio?</h2>
                <p class="text-on-surface-variant font-body-md mb-6">Auditoría, automatización y soluciones digitales B2B.</p>
                <span class="font-bold text-primary flex items-center gap-2 mt-auto">Ver servicios <span class="material-symbols-outlined notranslate" translate="no">arrow_forward</span></span>
            </a>

            <!-- Path 2: Recruiters -->
            <a href="/career" class="glass-card p-8 rounded-2xl flex flex-col items-center text-center group hover:border-primary/50 transition-all hover:-translate-y-1 hover:shadow-[0_0_30px_rgba(137,206,255,0.15)] relative overflow-hidden">
                <div class="absolute inset-0 bg-primary/5 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                <span class="material-symbols-outlined notranslate text-[48px] text-primary mb-4" translate="no">badge</span>
                <h2 class="font-headline-md text-2xl text-on-surface mb-3 group-hover:text-primary transition-colors">¿Eres reclutador o headhunter evaluando mi perfil?</h2>
                <p class="text-on-surface-variant font-body-md mb-6">Backend Developer Junior (Python, FastAPI, PostgreSQL).</p>
                <span class="font-bold text-primary flex items-center gap-2 mt-auto">Ver perfil profesional <span class="material-symbols-outlined notranslate" translate="no">arrow_forward</span></span>
            </a>
        </div>
    </section>

    <!-- Value Proposition -->
    <section class="py-section-gap px-gutter max-w-container-max mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-gutter">
            <div class="md:col-span-8 glass-card p-10 rounded-2xl relative overflow-hidden group hover:border-primary/30 transition-all duration-500 hover:shadow-[0_0_30px_rgba(137,206,255,0.1)]">
                <div class="relative z-10">
                    <span class="font-label-caps text-label-caps text-primary mb-4 block uppercase tracking-widest">Filosofía de Trabajo</span>
                    <h2 class="font-headline-md text-headline-md text-on-surface mb-6 max-w-lg leading-tight group-hover:drop-shadow-[0_0_8px_rgba(137,206,255,0.3)] transition-all">Más allá de la tecnología: Resolviendo la raíz del problema</h2>
                    <p class="text-on-surface-variant font-body-lg max-w-2xl mb-8 leading-relaxed">
                        Entender el contexto es fundamental. Cada solución tecnológica que implemento está diseñada tras un análisis exhaustivo de tu necesidad real. No busco aplicar parches temporales, sino construir puentes sólidos que conecten la problemática actual con una solución sostenible, humana y eficiente.
                    </p>
                    <div class="flex flex-wrap gap-4">
                        <div class="flex items-center gap-2 bg-surface-container-high px-4 py-2 rounded-lg border border-outline-variant/30 hover:border-primary/50 transition-colors">
                            <span class="material-symbols-outlined notranslate text-primary" translate="no">psychology</span>
                            <span class="font-code-sm text-code-sm">Análisis Profundo</span>
                        </div>
                        <div class="flex items-center gap-2 bg-surface-container-high px-4 py-2 rounded-lg border border-outline-variant/30 hover:border-primary/50 transition-colors">
                            <span class="material-symbols-outlined notranslate text-primary" translate="no">nature</span>
                            <span class="font-code-sm text-code-sm">Tecnología Consciente</span>
                        </div>
                    </div>
                </div>
                <div class="absolute top-0 right-0 w-1/2 h-full opacity-5 pointer-events-none group-hover:opacity-10 transition-opacity duration-700">
                    <span class="material-symbols-outlined notranslate text-[320px] text-primary absolute -right-10 -top-10" translate="no" style="font-variation-settings: 'FILL' 1;">water_drop</span>
                </div>
            </div>
            
            <div class="md:col-span-4 bg-primary-container p-10 rounded-2xl flex flex-col justify-between text-on-primary-container border border-primary hover:shadow-[0_0_40px_rgba(14,165,233,0.3)] transition-all duration-500 group">
                <div>
                    <span class="material-symbols-outlined notranslate text-[48px] mb-6 group-hover:scale-110 transition-transform duration-300" translate="no">balance</span>
                    <h3 class="font-headline-md text-headline-md font-bold mb-4">Equilibrio Técnico</h3>
                    <p class="font-body-md opacity-90 leading-relaxed">
                        Creo fielmente en que la naturaleza y la tecnología pueden convivir y potenciarse. Mis arquitecturas buscan ser lo más eficientes posibles, consumiendo solo los recursos necesarios.
                    </p>
                </div>
                <a class="mt-8 font-bold flex items-center gap-2 group-hover:translate-x-2 transition-transform" href="/metodologia">
                    Conoce mi metodología <span class="material-symbols-outlined notranslate" translate="no">arrow_right_alt</span>
                </a>
            </div>
        </div>
    </section>

    <!-- The Importance of Case Studies -->
    <section class="py-section-gap bg-surface-container-lowest/50 animate-on-scroll relative">
        <!-- Decoración sutil -->
        <div class="absolute left-0 top-1/2 -translate-y-1/2 w-32 h-32 bg-primary/20 blur-[100px] rounded-full"></div>

        <div class="max-w-container-max mx-auto px-gutter">
            <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6 relative z-10">
                <div class="max-w-2xl">
                    <h2 class="font-display-lg text-display-lg-mobile md:text-headline-md text-on-surface mb-4">El valor de la Experiencia</h2>
                    <p class="text-on-surface-variant font-body-lg">
                        La mejor forma de demostrar mi compromiso con la solución de problemas es mostrarte cómo he abordado los retos del pasado. Cada caso de estudio es un viaje desde la problemática hasta la implementación tecnológica.
                    </p>
                </div>
                <a href="/casos" class="text-primary font-bold flex items-center gap-2 group hover:drop-shadow-[0_0_8px_rgba(137,206,255,0.8)] transition-all">
                    Explorar el historial <span class="material-symbols-outlined notranslate group-hover:translate-x-1 transition-transform" translate="no">trending_flat</span>
                </a>
            </div>
            
                <div class="col-span-full w-full relative z-10">
                    <CasesCarousel />
                </div>
        </div>
    </section>

    <!-- Section 3 & 4: Contact Details & Form -->
    <section class="py-section-gap px-gutter animate-on-scroll bg-surface-container-lowest/50" id="contact">
        <div class="max-w-container-max mx-auto grid grid-cols-1 lg:grid-cols-2 gap-gutter">
            <!-- Contact Details -->
            <div class="flex flex-col justify-between py-8">
                <div>
                    <h2 class="font-display-lg text-display-lg-mobile md:text-[40px] mb-6 leading-tight">¿Tienes un reto técnico?<br/><span class="text-primary">Hablemos de ello.</span></h2>
                    <p class="text-on-surface-variant text-body-lg mb-12 max-w-md">Si buscas optimizar tu flujo de trabajo, construir una solución digital sólida, o buscas sumar un Desarrollador Backend Junior a tu equipo, estoy a un mensaje de distancia.</p>
                    
                    <div class="space-y-6">
                        <a class="flex items-center gap-6 p-6 glass-card rounded-2xl group hover:border-primary/50 hover:bg-surface-container-low transition-all" href="mailto:pablovaldescontacto@gmail.com">
                            <div class="w-14 h-14 bg-surface-container-high rounded-xl flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
                                <span class="material-symbols-outlined notranslate text-[28px]" translate="no">mail</span>
                            </div>
                            <div>
                                <p class="font-code-sm text-[12px] text-on-surface-variant uppercase">Email Directo</p>
                                <p class="font-headline-md text-body-lg text-on-surface group-hover:text-primary transition-colors">pablovaldescontacto@gmail.com</p>
                            </div>
                        </a>
                        <a class="flex items-center gap-6 p-6 glass-card rounded-2xl group hover:border-primary/50 hover:bg-surface-container-low transition-all" href="https://www.instagram.com/renkaidev/" target="_blank" rel="noopener noreferrer">
                            <div class="w-14 h-14 bg-surface-container-high rounded-xl flex items-center justify-center text-[#E1306C] group-hover:scale-110 transition-transform">
                                <span class="material-symbols-outlined notranslate text-[28px]" translate="no">photo_camera</span>
                            </div>
                            <div>
                                <p class="font-code-sm text-[12px] text-on-surface-variant uppercase">Instagram</p>
                                <p class="font-headline-md text-body-lg text-on-surface group-hover:text-primary transition-colors">@renkaidev</p>
                            </div>
                        </a>
                        <a class="flex items-center gap-6 p-6 glass-card rounded-2xl group hover:border-primary/50 hover:bg-surface-container-low transition-all" href="https://www.linkedin.com/in/pablo-vald%C3%A9s-6a4b0930b/" target="_blank" rel="noopener noreferrer">
                            <div class="w-14 h-14 bg-surface-container-high rounded-xl flex items-center justify-center text-[#0077B5] group-hover:scale-110 transition-transform">
                                <span class="material-symbols-outlined notranslate text-[28px]" translate="no">work</span>
                            </div>
                            <div>
                                <p class="font-code-sm text-[12px] text-on-surface-variant uppercase">LinkedIn Profile</p>
                                <p class="font-headline-md text-body-lg text-on-surface group-hover:text-primary transition-colors">in/pablo-valdés</p>
                            </div>
                        </a>
                    </div>
                </div>
            </div>

            <ContactForm />
        </div>
    </section>
  </main>
  
  <Footer />
</Layout>
