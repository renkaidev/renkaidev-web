---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const caseStudies = await getCollection('casos-estudio');
  return caseStudies.map(study => ({
    params: { id: study.id },
    props: { study },
  }));
}

const { study } = Astro.props;
const { Content } = await render(study);
---

<Layout title={`${study.data.title} | Caso de Estudio`} description={study.data.description}>
  <Header />
  
  <main class="pt-20">
    <article class="py-section-gap px-gutter max-w-container-max mx-auto animate-on-scroll">
      
      <!-- Back button -->
      <div class="mb-12">
        <a href="/casos" class="inline-flex items-center text-primary font-code-sm text-sm hover:-translate-x-2 transition-transform duration-300">
          <span class="material-symbols-outlined notranslate mr-2" translate="no">arrow_back</span>
          Volver a Casos de Estudio
        </a>
      </div>

      <div class="glass-card p-12 md:p-16 rounded-2xl relative overflow-hidden">
        <!-- Glow effect -->
        <div class="absolute top-0 right-0 p-8 opacity-20 pointer-events-none">
          <div class="w-64 h-64 bg-primary/30 rounded-full blur-[100px]"></div>
        </div>

        <header class="mb-16 border-b border-outline-variant/20 pb-12 relative z-10">
          <div class="flex flex-wrap gap-4 items-center mb-6">
            <span class="font-code-sm text-sm px-4 py-1.5 rounded-full bg-primary/10 text-primary border border-primary/20">
              {study.data.status}
            </span>
            <span class="font-code-sm text-on-surface-variant bg-surface-container px-3 py-1.5 rounded">
              {study.data.year}
            </span>
            {study.data.role && (
              <span class="font-code-sm text-on-surface-variant">
                / {study.data.role}
              </span>
            )}
          </div>
          
          <h1 class="font-display-lg text-display-lg-mobile md:text-display-lg text-on-surface mb-8">
            {study.data.title}
          </h1>
          
          <p class="font-body-lg text-body-lg text-on-surface-variant max-w-3xl">
            {study.data.description}
          </p>

          {study.data.tags && (
            <div class="flex flex-wrap gap-3 mt-10">
              {study.data.tags.map(tag => (
                <span class="font-code-sm text-sm bg-surface-container-high text-on-surface px-4 py-2 rounded-lg border border-outline-variant/30 shadow-sm">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </header>

        <div class="markdown-content relative z-10">
          <Content />
        </div>
      </div>
    </article>
  </main>
  
  <Footer />
</Layout>

<style is:global>
  .markdown-content h2 {
    font-family: 'Geist', sans-serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-on-surface, #E2E2E2);
    margin-top: 3rem;
    margin-bottom: 1.5rem;
  }
  
  .markdown-content p {
    font-family: 'Inter', sans-serif;
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--color-on-surface-variant, #A3A3A3);
    margin-bottom: 1.5rem;
  }
  
  .markdown-content ul {
    list-style-type: none;
    padding-left: 0;
    margin-bottom: 2rem;
  }
  
  .markdown-content li {
    font-family: 'Inter', sans-serif;
    font-size: 1.125rem;
    color: var(--color-on-surface-variant, #A3A3A3);
    margin-bottom: 0.75rem;
    position: relative;
    padding-left: 1.5rem;
  }
  
  .markdown-content li::before {
    content: "•";
    color: var(--color-primary, #89CEFF);
    position: absolute;
    left: 0;
    font-weight: bold;
  }
  
  .markdown-content strong {
    color: var(--color-on-surface, #E2E2E2);
    font-weight: 600;
  }
  
  .markdown-content a {
    color: var(--color-primary, #89CEFF);
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: opacity 0.2s;
  }
  
  .markdown-content a:hover {
    opacity: 0.8;
  }
</style>
